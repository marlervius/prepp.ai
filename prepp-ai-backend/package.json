{
  "name": "prepp-ai-backend",
  "version": "1.0.0",
  "description": "FastAPI backend for Prepp.ai",
  "main": "app/main.py",
  "scripts": {
    "start": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "dev": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "build": "pip install -r requirements.txt"
  },
  "keywords": ["fastapi", "ai", "education", "norway"],
  "author": "Prepp.ai",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  }
}