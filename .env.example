# ──────────────────────────────────────────────────────
# Prepp.ai — Environment Variables
# Copy to .env and fill in your values
# On Render, set these in the Dashboard or render.yaml
# ──────────────────────────────────────────────────────

# Database (Supabase)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres

# AI API Keys
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# Redis (local: redis://localhost:6379, Render: auto from render.yaml)
REDIS_URL=redis://localhost:6379

# External APIs
SNL_API_KEY=your-snl-api-key

# CORS — comma-separated origins
# Local:  http://localhost:3000,http://localhost:3001
# Render: https://prepp-ai-frontend.onrender.com,https://prepp.ai
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Application
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=true
LOG_LEVEL=INFO
