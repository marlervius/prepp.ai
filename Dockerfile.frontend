# Frontend Dockerfile for Render
FROM node:18-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY ./prepp-ai-app/package*.json ./

# Install dependencies
RUN npm ci --only=production

# Copy application code
COPY ./prepp-ai-app/ .

# Build application
RUN npm run build

# Expose port
EXPOSE 3000

# Start application
CMD ["npm", "start"]